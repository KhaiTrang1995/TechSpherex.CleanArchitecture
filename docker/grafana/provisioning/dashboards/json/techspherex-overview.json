{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "🚀 Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{service=\"techspherex-api\"}[5m])",
          "legendFormat": "{{http_request_method}} {{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme" },
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      }
    },
    {
      "title": "⏱️ P99 Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_request_duration_seconds_bucket{service=\"techspherex-api\"}[5m]))",
          "legendFormat": "P99 {{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" },
          "unit": "s"
        }
      }
    },
    {
      "title": "❌ Error Rate (5xx)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service=\"techspherex-api\",http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{service=\"techspherex-api\"}[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "📊 Active Connections",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(http_server_active_requests{service=\"techspherex-api\"})",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "🏥 Health Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "up{job=\"techspherex-api\"}",
          "legendFormat": "API"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "title": "💾 Memory Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "process_runtime_dotnet_gc_heap_size_bytes{service=\"techspherex-api\"}",
          "legendFormat": "Heap Size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "scheme" },
          "unit": "bytes",
          "color": { "mode": "continuous-blues" }
        }
      }
    },
    {
      "title": "📝 Log Volume by Level",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({service=\"techspherex-api\"} [5m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "🔍 Recent Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "{service=\"techspherex-api\"} |= ``",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "🔗 HTTP Status Code Distribution",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (http_response_status_code) (increase(http_server_request_duration_seconds_count{service=\"techspherex-api\"}[1h]))",
          "legendFormat": "{{http_response_status_code}}"
        }
      ]
    },
    {
      "title": "🧵 Thread Pool Queue Length",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "targets": [
        {
          "expr": "process_runtime_dotnet_thread_pool_queue_length{service=\"techspherex-api\"}",
          "legendFormat": "Queue Length"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "color": { "fixedColor": "purple", "mode": "fixed" }
        }
      }
    },
    {
      "title": "🗑️ GC Collections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "targets": [
        {
          "expr": "rate(process_runtime_dotnet_gc_collections_count_total{service=\"techspherex-api\"}[5m])",
          "legendFormat": "Gen {{generation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 },
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["techspherex", "dotnet", "clean-architecture"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "TechSpherex API Overview",
  "uid": "techspherex-overview",
  "version": 1
}
